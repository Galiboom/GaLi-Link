.container {
  width: 100vw;
  height: 100vh;
  background: #020617;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.liquid-bg {
  position: absolute;
  width: 600rpx;
  height: 600rpx;
  background: linear-gradient(135deg, #00f2ff, #7000ff);
  filter: blur(100px);
  border-radius: 50%;
  z-index: 1;
  animation: move 10s infinite alternate;
}

@keyframes move {
  from { transform: translate(-10%, -10%); }
  to { transform: translate(10%, 10%); }
}

.glass-card {
  position: relative;
  z-index: 10;
  width: 85%;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 60rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}

.status-bar { display: flex; justify-content: center; align-items: center; margin-bottom: 40rpx; }
.device-name { color: rgba(255, 255, 255, 0.6); font-size: 28rpx; }
.dot { width: 12rpx; height: 12rpx; background: #475569; border-radius: 50%; margin-left: 15rpx; }
.dot.online { background: #00f2ff; box-shadow: 0 0 15rpx #00f2ff; }

.hr-value { color: #fff; font-size: 160rpx; font-weight: 800; display: block; line-height: 1; text-shadow: 0 0 30rpx rgba(255,255,255,0.2); }
.unit { color: rgba(255, 255, 255, 0.4); font-size: 32rpx; margin-top: 20rpx; display: block; }

.action-btn {
  margin-top: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 28rpx;
}